{
  "name": "etyon",
  "version": "0.1.0",
  "private": true,
  "description": "Etyon monorepo",
  "keywords": [],
  "license": "MIT",
  "author": {
    "name": "etcetera",
    "email": "yilonglei790@gmail.com"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@etyon/desktop",
    "fix": "turbo run fix",
    "lint": "turbo run lint",
    "prepare": "lefthook install",
    "test": "vp test --config vitest.workspace.ts",
    "test:watch": "vp test watch --config vitest.workspace.ts",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.root.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "cz-git": "^1.12.0",
    "lefthook": "^2.1.4",
    "turbo": "^2.9.4",
    "typescript": "catalog:",
    "ultracite": "7.4.2",
    "vite-plus": "^0.1.15"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "fs-xattr",
      "lefthook",
      "macos-alias",
      "msw"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
