{
  "name": "etyon",
  "version": "0.1.5",
  "private": true,
  "description": "Etyon monorepo",
  "keywords": [],
  "license": "MIT",
  "author": {
    "name": "etcetera",
    "email": "yilonglei790@gmail.com"
  },
  "scripts": {
    "build": "turbo run build",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:latest": "git-cliff --latest --strip header",
    "check": "turbo run check",
    "clean:cache": "node script/clean-cache.mjs",
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@etyon/desktop",
    "fix": "turbo run fix",
    "lint": "turbo run lint",
    "fmt": "vp fmt . --write",
    "make": "turbo run make",
    "prepare": "vp config",
    "sherif": "sherif",
    "rust:check": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets --all-features -- -D warnings && cargo deny check bans licenses sources",
    "rust:clippy": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "rust:deny": "cargo deny check bans licenses sources",
    "rust:fmt": "cargo fmt --all",
    "rust:fmt:check": "cargo fmt --all -- --check",
    "rust:test": "cargo nextest run --workspace",
    "test": "vp test",
    "test:watch": "vp test watch",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.root.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "cz-git": "^1.13.1",
    "sherif": "^1.11.1",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.0",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.9.0"
}
