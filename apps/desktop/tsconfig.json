{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@renderer/*": ["./src/renderer/*"],
      "@main/*": ["./src/main/*"],
      "@preload/*": ["./src/preload/*"],
      "@etyon/logger/*": ["../../packages/logger/src/*"],
      "@etyon/rpc": ["../../packages/rpc/src/index.ts"],
      "@etyon/rpc/*": ["../../packages/rpc/src/*"],
      "@etyon/ui/*": ["../../packages/ui/src/*"]
    },
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "forge.env.d.ts"]
}
