{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@etyon/i18n": ["../../packages/i18n/src/index.ts"],
      "@etyon/i18n/react": ["../../packages/i18n/src/react.tsx"],
      "@etyon/logger/renderer": ["../../packages/logger/src/renderer.ts"],
      "@etyon/logger/types": ["../../packages/logger/src/types.ts"],
      "@etyon/rpc": ["../../packages/rpc/src/index.ts"],
      "@etyon/rpc/*": ["../../packages/rpc/src/*"],
      "@etyon/ui/components/*": ["../../packages/ui/src/components/*"],
      "@etyon/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@etyon/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@etyon/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@main/*": ["./src/main/*"],
      "@preload/*": ["./src/preload/*"],
      "@renderer/*": ["./src/renderer/*"]
    },
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "forge.env.d.ts"]
}
